# ==============================================
# BRIGHTEN LIGHTING - FREE-FOREVER STACK CONFIG
# ==============================================

# Server
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS) - GitHub Pages domain
FRONTEND_URL=https://yourusername.github.io/brightenlighting

# Database - MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/brightenlighting?retryWrites=true&w=majority

# Session
SESSION_SECRET=your-secure-random-session-secret-here

# Admin Credentials
ADMIN_USER=admin
ADMIN_PASS=your-secure-admin-password

# M-Pesa Integration (Safaricom Daraja)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd1a503b6e
MPESA_CALLBACK_URL=https://your-render-url.onrender.com/mpesa/callback

# Notes:
# 1. Generate SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 2. Get M-Pesa credentials from: https://developer.safaricom.co.ke/
# 3. MongoDB Atlas free tier: https://www.mongodb.com/cloud/atlas
# 4. Update FRONTEND_URL with your actual GitHub Pages domain
# 5. Update MPESA_CALLBACK_URL with your actual Render.com domain
